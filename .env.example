# ===========================
# Server Configuration
# ===========================
DOMAIN=yourdomain.com
ENVIRONMENT=production

# ===========================
# PostgreSQL
# ===========================
POSTGRES_DB=voiceai
POSTGRES_USER=voiceai_user
POSTGRES_PASSWORD=your_strong_password_here
# DATABASE_URL must use the same values as POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above
DATABASE_URL=postgresql://voiceai_user:your_strong_password_here@postgres:5432/voiceai

# ===========================
# Redis
# ===========================
REDIS_URL=redis://redis:6379/0

# ===========================
# API Security
# ===========================
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key_here

# ===========================
# LiveKit
# ===========================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ===========================
# Twilio
# ===========================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ===========================
# Deepgram
# ===========================
DEEPGRAM_API_KEY=your_deepgram_api_key

# ===========================
# Rime
# ===========================
RIME_API_KEY=your_rime_api_key

# ===========================
# LLM (choose one)
# ===========================
OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
